# search-mcp configuration
# All values shown are the defaults used if a variable is missing or unset.

# --- Search limits ---
SEARCH_MAX_RESULTS=5
SEARCH_MAX_PAGES=5
NEWS_MAX_RESULTS=5
# Full-cascade retry passes when every provider returns nothing.
SEARCH_RETRY_ATTEMPTS=2
# "auto" = pick region from the query language; or pin e.g. "ru-ru", "us-en".
SEARCH_REGION=auto

# --- Networking ---
PAGE_TIMEOUT=8
REQUEST_MAX_WORKERS=4
# Hard cap on downloaded page size (bytes) - memory protection.
MAX_HTML_BYTES=2000000
# Minimum seconds between requests to the same search provider.
PROVIDER_MIN_INTERVAL=2.0
# Base cooldown (seconds) for a provider after it blocks/fails; doubles per failure.
PROVIDER_COOLDOWN=120
USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 12_7_6) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# --- Content limits (keep these small so Gemma 3 4B isn't fed huge contexts) ---
MAX_CHARS_PER_PAGE=4000
MAX_TOTAL_CHARS=20000

# --- Cache ---
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=256
CACHE_MAX_MEMORY_MB=32
PAGE_TTL_SECONDS=900
WEATHER_TTL_SECONDS=600
CURRENCY_TTL_SECONDS=3600
WIKI_TTL_SECONDS=86400

# --- Misc ---
# Default timezone for current_time/current_date with no location
# (empty = server's local timezone). Example: Europe/Moscow
DEFAULT_TIMEZONE=
LOG_LEVEL=INFO
# Log a statistics summary every N tool calls (0 = never).
STATS_LOG_EVERY=20
