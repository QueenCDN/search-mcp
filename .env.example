# search-mcp configuration
# All values shown are the defaults used if a variable is missing or unset.

# --- Search limits ---
SEARCH_MAX_RESULTS=5
SEARCH_MAX_PAGES=5
NEWS_MAX_RESULTS=5

# --- Networking ---
PAGE_TIMEOUT=8
REQUEST_MAX_WORKERS=4
USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 12_7_6) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# --- Content limits (keep these small so Gemma 3 4B isn't fed huge contexts) ---
MAX_CHARS_PER_PAGE=4000
MAX_TOTAL_CHARS=20000

# --- Cache ---
CACHE_TTL_SECONDS=300

# --- Logging ---
LOG_LEVEL=INFO
